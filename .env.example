# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_DATABASE=alarm
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# 模型配置
MODEL_PROVIDER=siliconflow
MODEL_API_KEY=your_siliconflow_api_key
MODEL_BASE_URL=https://api.siliconflow.cn/v1
MODEL_MODEL_NAME=deepseek-ai/DeepSeek-V3
MODEL_TEMPERATURE=0.1
MODEL_MAX_TOKENS=4096
MODEL_TIMEOUT=60

# LangSmith 配置（可选）
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=

# 图像保存路径
IMAGE_BASE_DIR=./images

# HITL 配置
ENABLE_HITL=false
HITL_TIMEOUT_SECONDS=300

# Checkpointer 配置（memory/sqlite）
CHECKPOINTER_BACKEND=memory
# 当 CHECKPOINTER_BACKEND=sqlite 时生效
CHECKPOINTER_PATH=./.langgraph_checkpoints.sqlite
